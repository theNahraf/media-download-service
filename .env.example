# === Database ===
POSTGRES_USER=mediadown
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mediadownload
DATABASE_URL=postgresql+asyncpg://mediadown:change_me_in_production@postgres:5432/mediadownload

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Google Drive Storage (OAuth2) ===
# Run: python3 setup_gdrive_oauth.py to generate these values
GDRIVE_CLIENT_ID=your_oauth_client_id
GDRIVE_CLIENT_SECRET=your_oauth_client_secret
GDRIVE_REFRESH_TOKEN=your_refresh_token
GDRIVE_FOLDER_ID=your_shared_folder_id

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# === Rate Limiting ===
RATE_LIMIT_PER_HOUR=30
RATE_LIMIT_BURST=5

# === Worker ===
WORKER_CONCURRENCY=4
MAX_DOWNLOAD_TIMEOUT=900
MAX_FILE_SIZE_MB=5120

# === Download Settings ===
DOWNLOAD_EXPIRY_HOURS=24
SIGNED_URL_EXPIRY_SECONDS=3600
