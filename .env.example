# === Database ===
POSTGRES_USER=mediadown
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mediadownload
DATABASE_URL=postgresql+asyncpg://mediadown:change_me_in_production@postgres:5432/mediadownload

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO (S3-compatible) ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change_me_in_production
S3_BUCKET_NAME=media-downloads
S3_PUBLIC_URL=http://localhost:9000

# === API ===
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# === Rate Limiting ===
RATE_LIMIT_PER_HOUR=30
RATE_LIMIT_BURST=5

# === Worker ===
WORKER_CONCURRENCY=4
MAX_DOWNLOAD_TIMEOUT=900
MAX_FILE_SIZE_MB=5120

# === Download Settings ===
DOWNLOAD_EXPIRY_HOURS=24
SIGNED_URL_EXPIRY_SECONDS=3600
